{
	"name": "compressor-frontend",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/glb-compressor.git",
		"directory": "compressor-frontend"
	},
	"scripts": {
		"bd": "bun --bun run build",
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"lint": "eslint .",
		"prepare": "bunx --bun svelte-kit sync",
		"preview": "bun bd && vite preview",
		"test": "vitest run",
		"test:unit": "vitest"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@glb-compressor/shared-types": "workspace:*",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.18",
		"eslint": "^9.39.2",
		"eslint-plugin-svelte": "3.14.0",
		"globals": "^17.3.0",
		"playwright": "^1.58.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	}
}
