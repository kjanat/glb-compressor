{
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noPropertyAccessFromIndexSignature": false,

		// Interop with CommonJS modules
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,

		// Path aliases
		"paths": {
			"@glb-compressor/core": ["./packages/core/src/mod.ts"],
			"@glb-compressor/cli": ["./packages/cli/src/main.ts"],
			"@glb-compressor/server": ["./packages/server/src/main.ts"],
			"@glb-compressor/shared-types": ["./packages/shared-types/src/index.ts"],
			"$models": ["./models/*"],
			"pkg": ["./package.json"]
		}
	},
	"exclude": [
		"packages/*/src",
		"compressor-frontend",
		"shitty-frontend",
		"dist",
		"node_modules"
	]
}
