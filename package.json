{
	"name": "glb-compressor",
	"version": "1.0.2",
	"description": "Multi-phase GLB/glTF 3D model compression CLI, HTTP server & library",
	"keywords": [
		"glb",
		"gltf",
		"3d",
		"compression",
		"mesh",
		"meshopt",
		"meshoptimizer",
		"gltfpack",
		"draco",
		"webp",
		"avatar",
		"skinned",
		"animation",
		"texture",
		"cli",
		"server",
		"sse",
		"gltf-transform"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/glb-compressor.git"
	},
	"homepage": "https://glb-compressor.kjanat.com/",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/types/packages/core/src/mod.d.ts",
			"bun": "./dist/bun/core/src/mod.js",
			"node": "./dist/node/core/src/mod.js",
			"default": "./dist/node/core/src/mod.js"
		},
		"./server": {
			"types": "./dist/types/packages/server/src/main.d.ts",
			"bun": "./dist/bun-bytecode/server/src/main.cjs",
			"node": "./dist/node/server/src/main.js",
			"default": "./dist/node/server/src/main.js"
		},
		"./cli": {
			"types": "./dist/types/packages/cli/src/main.d.ts",
			"bun": "./dist/bun-bytecode/cli/src/main.cjs",
			"node": "./dist/node/cli/src/main.js",
			"default": "./dist/node/cli/src/main.js"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/node/core/src/mod.js",
	"types": "./dist/types/packages/core/src/mod.d.ts",
	"bin": {
		"glb-compressor": "bin/glb-compressor.js",
		"glb-server": "bin/glb-server.js"
	},
	"files": [
		"bin",
		"src",
		"dist/node/**/*.*js",
		"dist/bun/**/*.*js",
		"dist/bun-bytecode/**/*.{cjs,cjs.jsc}",
		"dist/types",
		"CHANGELOG.md",
		"skills"
	],
	"workspaces": [
		"packages/*",
		"compressor-frontend",
		"shitty-frontend"
	],
	"scripts": {
		"bd": "bun run build",
		"build": "bun build.ts",
		"check": "biome check",
		"cli": "bun --bun packages/cli/src/main.ts",
		"dev": "bun --hot run packages/server/src/main.ts",
		"fmt": "dprint fmt",
		"licences": "bunx license-checker --production --json --out licenses.json",
		"lint": "biome lint",
		"prepublishOnly": "bunx prettier README.md --write",
		"start": "bun --bun packages/server/src/main.ts",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@glb-compressor/cli": "workspace:*",
		"@glb-compressor/core": "workspace:*",
		"@glb-compressor/server": "workspace:*",
		"@glb-compressor/shared-types": "workspace:*",
		"@gltf-transform/core": "4.3.0",
		"@gltf-transform/extensions": "4.3.0",
		"@gltf-transform/functions": "4.3.0",
		"draco3dgltf": "1.5.7",
		"meshoptimizer": "1.0.1",
		"sharp": "0.34.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@glb-compressor/bun-polyfill": "workspace:*",
		"@types/bun": "1.3.10",
		"@types/draco3dgltf": "1.4.3",
		"@typescript/native-preview": "7.0.0-dev.20260309.1",
		"dprint": "0.51.1"
	},
	"packageManager": "bun@1.3.10",
	"engines": {
		"bun": ">=1.3",
		"node": ">=18.17.0"
	}
}
